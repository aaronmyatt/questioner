# For local preview of the GitHub Pages site:
#
#   cd docs && bundle install && bundle exec jekyll serve
#
# The github-pages gem pins Jekyll and plugins to the exact versions GitHub
# Pages runs server-side, so a clean local build matches production.
# Ref: https://github.com/github/pages-gem
source "https://rubygems.org"

gem "github-pages", group: :jekyll_plugins

# Ruby 3.0+ removed webrick from the standard library; Jekyll's local server
# needs it. https://github.com/jekyll/jekyll/issues/8523
gem "webrick", "~> 1.8"
